@model TaskDetailDto
@{
    ViewData["Title"] = "Task Detail";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h2 class="h5 mb-1">@Model.Title</h2>
                <div class="text-muted">@Model.TypeCode</div>
            </div>
            <span class="badge bg-@StatusBadge(Model.StatusCode)">@Model.StatusName</span>
        </div>

        <dl class="row">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description)</dd>

            <dt class="col-sm-3">Deadline</dt>
            <dd class="col-sm-9">@(Model.Deadline?.ToString("yyyy-MM-dd HH:mm") ?? "No deadline")</dd>

            <%-- B6 FIX: Show human-readable "Page N" instead of raw UUID --%>
            <dt class="col-sm-3">Page</dt>
            <dd class="col-sm-9">
                @if (Model.PageNumber.HasValue)
                {
                    <span>Page @Model.PageNumber</span>
                }
                else
                {
                    <span class="text-muted">N/A</span>
                }
            </dd>

            <dt class="col-sm-3">Assigned To</dt>
            <dd class="col-sm-9">@(Model.AssignedToUserName ?? "Current assistant")</dd>

            <dt class="col-sm-3">Instructions</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Instructions) ? "No extra instructions." : Model.Instructions)</dd>
        </dl>

        <div class="d-flex gap-2">
            @if (Model.StatusCode == "Assigned")
            {
                <form method="post" asp-area="Assistant" asp-controller="Tasks" asp-action="Start">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskId" value="@Model.TaskId" />
                    <button type="submit" class="btn btn-primary">Start Task</button>
                </form>
            }
            @if (Model.StatusCode == "InProgress")
            {
                <a class="btn btn-success" asp-area="Assistant" asp-controller="Submissions" asp-action="Submit" asp-route-taskId="@Model.TaskId">Submit Work</a>
            }
            <a class="btn btn-outline-secondary" asp-area="Assistant" asp-controller="Tasks" asp-action="Index">Back to Tasks</a>
        </div>
    </div>

    <div class="col-lg-4">
        @if (!string.IsNullOrWhiteSpace(Model.PageImageUrl))
        {
            <img src="@Model.PageImageUrl" alt="Manga page" class="img-fluid rounded border" />
        }
        else
        {
            <div class="border rounded bg-light text-muted d-flex align-items-center justify-content-center" style="min-height: 220px;">No page preview</div>
        }
    </div>
</div>

@functions {
    private static string StatusBadge(string statusCode) => statusCode switch
    {
        "Assigned" => "secondary",
        "InProgress" => "primary",
        "Submitted" => "info",
        "Approved" => "success",
        "Rejected" => "danger",
        "Overdue" => "warning text-dark",
        _ => "light text-dark"
    };
}
