@model SubmitTaskDto
@{
    ViewData["Title"] = "Submit Work";
    var taskId = Model?.TaskId ?? (ViewData["TaskId"] as Guid?) ?? Guid.Empty;
}

<h2 class="h5 mb-3">Submit Work</h2>

<form method="post" enctype="multipart/form-data" asp-area="Assistant" asp-controller="Submissions" asp-action="Submit">
    @Html.AntiForgeryToken()
    <input type="hidden" name="TaskId" value="@taskId" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="UploadedFile" class="form-label">Upload file</label>
        <input asp-for="UploadedFile" type="file" class="form-control" />
        <span asp-validation-for="UploadedFile" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Submit</button>
        <a class="btn btn-outline-secondary" asp-area="Assistant" asp-controller="Tasks" asp-action="Detail" asp-route-id="@taskId">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
