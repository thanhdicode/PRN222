@model MangaWorkflow.Application.DTOs.Board.SubmitVoteDto
@{
    ViewData["Title"] = "Submit Vote";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <h1 class="h3 mb-4">Cast Vote for '@ViewBag.SeriesTitle'</h1>

    <div class="card shadow-sm" style="max-width: 600px;">
        <div class="card-body">
            <form asp-action="Vote" method="post">
                <input type="hidden" asp-for="SeriesId" />
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <div class="mb-4">
                    <label class="form-label d-block fw-bold mb-3">Your Vote</label>
                    <div class="form-check form-check-inline mb-2">
                        <input class="form-check-input" type="radio" asp-for="VoteValueCode" value="Approve" id="voteApprove">
                        <label class="form-check-label text-success fw-bold" for="voteApprove">Approve</label>
                    </div>
                    <div class="form-check form-check-inline mb-2">
                        <input class="form-check-input" type="radio" asp-for="VoteValueCode" value="Revise" id="voteRevise">
                        <label class="form-check-label text-warning fw-bold" for="voteRevise">Revise & Resubmit</label>
                    </div>
                    <div class="form-check form-check-inline mb-2">
                        <input class="form-check-input" type="radio" asp-for="VoteValueCode" value="Reject" id="voteReject">
                        <label class="form-check-label text-danger fw-bold" for="voteReject">Reject</label>
                    </div>
                    <span asp-validation-for="VoteValueCode" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Comment" class="form-label fw-bold">Feedback / Comments</label>
                    <textarea asp-for="Comment" class="form-control" rows="5" placeholder="Explain your decision..."></textarea>
                    <span asp-validation-for="Comment" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Submit Vote</button>
                    <a asp-action="Details" asp-route-id="@Model.SeriesId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
