@model List<MangaWorkflow.Application.DTOs.Series.SeriesListItemDto>
@{
    ViewData["Title"] = "Editorial Board Review";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Pending Submissions</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm">
        <div class="list-group list-group-flush">
            @foreach (var series in Model)
            {
                <a asp-action="Details" asp-route-id="@series.SeriesId" class="list-group-item list-group-item-action p-3">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="bg-light rounded me-3 d-flex justify-content-center align-items-center text-muted" style="width: 50px; height: 50px;">Img</div>
                            <div>
                                <h5 class="mb-1">@series.Title</h5>
                                <p class="mb-1 text-muted small">@series.Genre | Submitted: @series.CreatedAt.ToString("d")</p>
                            </div>
                        </div>
                        <span class="badge bg-info">@series.StatusName</span>
                    </div>
                </a>
            }
            @if (!Model.Any())
            {
                <div class="list-group-item text-center text-muted py-4">
                    <p class="mb-0">No series currently pending review.</p>
                </div>
            }
        </div>
    </div>
</div>
