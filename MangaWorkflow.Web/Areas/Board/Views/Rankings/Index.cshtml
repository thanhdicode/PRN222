@{
    ViewData["Title"] = "Rankings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4">
        <h1 class="h3 mb-0 me-3">Rankings</h1>
        <span class="badge bg-warning text-dark">Coming Soon</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-trophy" style="font-size: 4rem; color: #ffc107;"></i>
            <h4 class="mt-3 mb-2">Series Rankings</h4>
            <p class="text-muted mb-4">
                The Rankings feature is under development.<br />
                It will display weekly and monthly series performance metrics<br />
                based on editorial board scores and reader engagement.
            </p>
            <a asp-area="Board" asp-controller="Review" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> Back to Series Review
            </a>
        </div>
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-header bg-light">
            <strong>Planned Features</strong>
        </div>
        <ul class="list-group list-group-flush">
            <li class="list-group-item">
                <i class="bi bi-check2-circle text-success me-2"></i>
                Weekly top series by vote score
            </li>
            <li class="list-group-item">
                <i class="bi bi-check2-circle text-success me-2"></i>
                Monthly aggregated rankings with trend arrows
            </li>
            <li class="list-group-item">
                <i class="bi bi-check2-circle text-success me-2"></i>
                Genre-filtered ranking views
            </li>
            <li class="list-group-item">
                <i class="bi bi-check2-circle text-success me-2"></i>
                Export rankings to CSV
            </li>
        </ul>
    </div>
</div>
