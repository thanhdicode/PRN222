@model List<MangaWorkflow.Application.DTOs.Chapters.ChapterListItemDto>
@{
    var series = (MangaWorkflow.Application.DTOs.Series.SeriesDetailDto)ViewBag.Series;
    ViewData["Title"] = $"Chapters - {series.Title}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Chapters: @series.Title</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-area="Mangaka" asp-controller="Series" asp-action="Index">My Series</a></li>
                    <li class="breadcrumb-item"><a asp-area="Mangaka" asp-controller="Series" asp-action="Details" asp-route-id="@series.SeriesId">@series.Title</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chapters</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Create" asp-route-seriesId="@series.SeriesId" class="btn btn-primary">+ Add Chapter</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm">
        <div class="list-group list-group-flush">
            @foreach (var chapter in Model)
            {
                <div class="list-group-item p-3">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">Chapter @chapter.ChapterNumber <small class="text-muted">@chapter.Title</small></h5>
                            <p class="mb-1 text-muted small">Status: <span class="badge bg-secondary">@chapter.StatusName</span> | Deadline: @chapter.Deadline?.ToString("d")</p>
                        </div>
                        <div>
                            <a asp-action="Details" asp-route-id="@chapter.ChapterId" class="btn btn-sm btn-outline-primary">View</a>
                            <a asp-action="Edit" asp-route-id="@chapter.ChapterId" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-area="Mangaka" asp-controller="Pages" asp-action="Index" asp-route-chapterId="@chapter.ChapterId" class="btn btn-sm btn-outline-info">Pages</a>
                        </div>
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <div class="list-group-item text-center text-muted py-4">
                    <p class="mb-0">No chapters yet. <a asp-action="Create" asp-route-seriesId="@series.SeriesId">Create the first chapter</a>.</p>
                </div>
            }
        </div>
    </div>
</div>
