@model MangaWorkflow.Application.DTOs.Pages.CreatePageDto
@{
    var chapter = (MangaWorkflow.Application.DTOs.Chapters.ChapterDetailDto)ViewBag.Chapter;
    ViewData["Title"] = "Upload Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <h1 class="h3 mb-4">Upload Page to Chapter @chapter.ChapterNumber</h1>

    <div class="card shadow-sm" style="max-width: 600px;">
        <div class="card-body">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="ChapterId" />
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="PageNumber" class="form-label"></label>
                    <input asp-for="PageNumber" class="form-control" />
                    <span asp-validation-for="PageNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UploadedFile" class="form-label"></label>
                    <input asp-for="UploadedFile" class="form-control" type="file" accept="image/jpeg,image/png,image/webp" />
                    <span asp-validation-for="UploadedFile" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Upload Page</button>
                    <a asp-action="Index" asp-route-chapterId="@Model.ChapterId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
