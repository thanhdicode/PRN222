@model List<MangaWorkflow.Application.DTOs.Pages.PageListItemDto>
@{
    var chapter = (MangaWorkflow.Application.DTOs.Chapters.ChapterDetailDto)ViewBag.Chapter;
    ViewData["Title"] = $"Pages - Chapter {chapter.ChapterNumber}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Pages: Chapter @chapter.ChapterNumber</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-area="Mangaka" asp-controller="Series" asp-action="Index">My Series</a></li>
                    <li class="breadcrumb-item"><a asp-area="Mangaka" asp-controller="Series" asp-action="Details" asp-route-id="@chapter.SeriesId">@chapter.SeriesTitle</a></li>
                    <li class="breadcrumb-item"><a asp-area="Mangaka" asp-controller="Chapters" asp-action="Details" asp-route-id="@chapter.ChapterId">Chapter @chapter.ChapterNumber</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Pages</li>
                </ol>
            </nav>
        </div>
        @if (chapter.StatusCode != "Draft" && chapter.StatusCode != "Published")
        {
            <a asp-action="Upload" asp-route-chapterId="@chapter.ChapterId" class="btn btn-primary">Upload Page</a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="row row-cols-2 row-cols-md-4 g-4">
        @foreach (var pageItem in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm text-center">
                    <img src="@pageItem.ImageUrl" class="card-img-top p-2" alt="Page @pageItem.PageNumber" style="object-fit: contain; height: 250px; background-color: #f8f9fa;" />
                    <div class="card-body p-2">
                        <h6 class="card-title mb-1">Page @pageItem.PageNumber (v@(pageItem.VersionNumber))</h6>
                        <span class="badge bg-secondary mb-2">@pageItem.StatusName</span>
                        <div class="d-grid">
                            <a asp-action="Details" asp-route-id="@pageItem.PageId" class="btn btn-sm btn-outline-primary">Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5 border rounded bg-light">
            <p class="mb-0">No pages uploaded yet.</p>
            @if (chapter.StatusCode != "Draft")
            {
                <a asp-action="Upload" asp-route-chapterId="@chapter.ChapterId" class="mt-2 btn btn-outline-primary">Upload the first page</a>
            }
            else
            {
                <p class="small text-danger mt-2">Chapter must be moved to 'In Production' before you can upload pages.</p>
            }
        </div>
    }
</div>
