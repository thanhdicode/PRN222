@model List<MangaWorkflow.Application.DTOs.Series.SeriesListItemDto>
@{
    ViewData["Title"] = "My Series";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">My Series</h1>
        <a asp-area="Mangaka" asp-controller="Series" asp-action="Create" class="btn btn-primary">+ New Series</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Filters -->
    <form method="get" class="row g-2 mb-4">
        <div class="col-auto">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="Search series..." />
        </div>
        <div class="col-auto">
            <select name="statusCode" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var s in (List<MangaWorkflow.Domain.Entities.SeriesStatus>)ViewBag.Statuses)
                {
                    <option value="@s.StatusCode" selected="@(s.StatusCode == ViewBag.SelectedStatus ? "selected" : null)">@s.StatusName</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-link">Clear</a>
        </div>
    </form>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var series in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(series.CoverImageUrl))
                    {
                        <img src="@series.CoverImageUrl" class="card-img-top mw-series-index-cover" alt="@series.Title cover" />
                    }
                    <div class="card-body">
                        @if (string.IsNullOrWhiteSpace(series.CoverImageUrl))
                        {
                            <div class="bg-light rounded d-flex justify-content-center align-items-center text-muted mb-3" style="height: 150px;">No Image</div>
                        }
                        <h5 class="card-title">@series.Title</h5>
                        <p class="text-muted small mb-1">@series.Genre</p>
                        <span class="badge bg-@(series.StatusCode == "Draft" ? "secondary" : series.StatusCode == "Submitted" ? "info" : "success")">
                            @series.StatusName
                        </span>
                        <p class="mt-2 small text-muted">@series.ChapterCount chapter(s)</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Details" asp-route-id="@series.SeriesId" class="btn btn-sm btn-outline-primary">View</a>
                        @if (series.StatusCode == "Draft")
                        {
                            <a asp-action="Edit" asp-route-id="@series.SeriesId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <p>No series found. <a asp-action="Create">Create your first series</a>.</p>
        </div>
    }
</div>
