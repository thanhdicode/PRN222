@model List<MangaWorkflow.Application.DTOs.Series.SeriesListItemDto>
@{
    ViewData["Title"] = "Mangaka Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var totalSeries = Model.Count;
    var draftCount = Model.Count(s => s.StatusCode == "Draft");
    var submittedCount = Model.Count(s => s.StatusCode == "Submitted" || s.StatusCode == "UnderReview");
    var approvedCount = Model.Count(s => s.StatusCode == "Approved" || s.StatusCode == "Publishing");
    var latestSeries = Model.OrderByDescending(s => s.CreatedAt).Take(6).ToList();
}

<div class="mangaka-dashboard py-4">
    <section class="mw-hero mb-4">
        <div>
            <p class="text-uppercase text-primary fw-semibold small mb-2">Mangaka workspace</p>
            <h1 class="display-6 fw-bold mb-2">Create, submit, and track your manga pipeline</h1>
            <p class="text-muted mb-0">Demo hub for MVC flows: series CRUD, chapter management, page upload, board submission, notifications, and AI Studio.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-area="Mangaka" asp-controller="Series" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> New Series
            </a>
            <a asp-area="Mangaka" asp-controller="Series" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-grid"></i> My Series
            </a>
            <a asp-area="" asp-controller="AiStudio" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-stars"></i> AI Studio
            </a>
        </div>
    </section>

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="mw-stat">
                <span class="text-muted small">Total series</span>
                <strong>@totalSeries</strong>
                <i class="bi bi-journal-richtext"></i>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="mw-stat">
                <span class="text-muted small">Draft</span>
                <strong>@draftCount</strong>
                <i class="bi bi-pencil-square"></i>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="mw-stat">
                <span class="text-muted small">In review</span>
                <strong>@submittedCount</strong>
                <i class="bi bi-send-check"></i>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="mw-stat">
                <span class="text-muted small">Approved / live</span>
                <strong>@approvedCount</strong>
                <i class="bi bi-award"></i>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Recent series</h2>
                <a asp-area="Mangaka" asp-controller="Series" asp-action="Index" class="btn btn-sm btn-outline-secondary">View all</a>
            </div>

            @if (latestSeries.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    @foreach (var series in latestSeries)
                    {
                        <div class="col">
                            <article class="mw-series-card">
                                <div class="mw-series-cover">
                                    @if (!string.IsNullOrWhiteSpace(series.CoverImageUrl))
                                    {
                                        <img src="@series.CoverImageUrl" alt="@series.Title cover" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image"></i>
                                    }
                                </div>
                                <div class="mw-series-body">
                                    <div class="d-flex justify-content-between gap-2">
                                        <h3 class="h6 mb-1">@series.Title</h3>
                                        <span class="badge @GetStatusBadge(series.StatusCode)">@series.StatusName</span>
                                    </div>
                                    <p class="text-muted small mb-2">@series.Genre</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="small text-muted">@series.ChapterCount chapter(s)</span>
                                        <a asp-area="Mangaka" asp-controller="Series" asp-action="Details" asp-route-id="@series.SeriesId" class="btn btn-sm btn-primary">Open</a>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="mw-empty">
                    <i class="bi bi-journal-plus"></i>
                    <p class="mb-2">No series yet.</p>
                    <a asp-area="Mangaka" asp-controller="Series" asp-action="Create" class="btn btn-primary">Create your first series</a>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="mw-panel mb-3">
                <h2 class="h5">Demo flow</h2>
                <div class="mw-flow">
                    <a asp-area="Mangaka" asp-controller="Series" asp-action="Create"><i class="bi bi-1-circle"></i><span>Create or edit series</span></a>
                    <a asp-area="Mangaka" asp-controller="Series" asp-action="Index"><i class="bi bi-2-circle"></i><span>Open details and submit for review</span></a>
                    <a asp-area="Board" asp-controller="Review" asp-action="Index"><i class="bi bi-3-circle"></i><span>Board reviews submitted series</span></a>
                    <a asp-area="" asp-controller="AiStudio" asp-action="Index"><i class="bi bi-4-circle"></i><span>Generate AI title / synopsis ideas</span></a>
                </div>
            </div>

            <div class="mw-panel">
                <h2 class="h5">SignalR proof</h2>
                <p class="text-muted small mb-3">Keep the notification bell visible. Submitting a series or board decision creates notification records and pushes them through the shared SignalR notification hub.</p>
                <div class="alert alert-info mb-0">
                    <i class="bi bi-bell"></i> Watch the navbar notification badge while testing cross-role actions.
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string GetStatusBadge(string statusCode) => statusCode switch
    {
        "Draft" => "bg-secondary",
        "Submitted" => "bg-info text-dark",
        "UnderReview" => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Publishing" => "bg-primary",
        "RevisionRequired" => "bg-danger",
        "Cancelled" => "bg-dark",
        _ => "bg-light text-dark"
    };
}
