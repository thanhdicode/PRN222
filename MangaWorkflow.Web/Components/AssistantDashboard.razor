@using MangaWorkflow.Application.DTOs.Dashboard
@using MangaWorkflow.Application.Interfaces.Services
@inject IDashboardService DashboardService

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card bg-primary text-white h-100">
            <div class="card-body">
                <h5 class="card-title">Active Tasks</h5>
                <h2 class="mb-0">@Model?.ActiveTasksCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card bg-danger text-white h-100">
            <div class="card-body">
                <h5 class="card-title">Overdue Tasks</h5>
                <h2 class="mb-0">@Model?.OverdueTasksCount</h2>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Recent Tasks</h5>
    </div>
    <div class="card-body">
        @if (Model?.RecentTasks != null && Model.RecentTasks.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var task in Model.RecentTasks)
                {
                    <a href="/Assistant/SubmitTask?taskId=@task.TaskId" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-bold">@task.Description</div>
                            <small class="text-muted">Deadline: @task.Deadline.ToString("MMM dd, yyyy HH:mm")</small>
                        </div>
                        <span class="badge bg-secondary rounded-pill">@task.StatusCode</span>
                    </a>
                }
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No recent tasks.</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid UserId { get; set; }

    private AssistantDashboardDto? Model;

    protected override async Task OnInitializedAsync()
    {
        Model = await DashboardService.GetAssistantDashboardAsync(UserId);
    }
}
