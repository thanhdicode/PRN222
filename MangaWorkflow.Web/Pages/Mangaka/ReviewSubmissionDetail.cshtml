@page
@model MangaWorkflow.Web.Pages.Mangaka.ReviewSubmissionDetailModel
@{
    ViewData["Title"] = "Review Detail";
}

<div class="container py-4">
    <div class="mb-3">
        <a asp-page="/Mangaka/ReviewSubmissions" class="btn btn-outline-secondary">&laquo; Back to Pending List</a>
    </div>

    @if (Model.Submission == null)
    {
        <div class="alert alert-warning">Submission not found.</div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h4 class="mb-0">Review: @Model.Submission.TaskTitle</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Assistant:</strong> @Model.Submission.AssistantName</p>
                        <p><strong>Submitted At:</strong> @Model.Submission.SubmittedAt.ToString("g")</p>
                        <p><strong>Notes:</strong></p>
                        <div class="p-3 bg-light rounded text-muted">
                            @(string.IsNullOrEmpty(Model.Submission.Notes) ? "No notes provided." : Model.Submission.Notes)
                        </div>
                    </div>
                    <div class="col-md-6 text-center">
                        @if (!string.IsNullOrEmpty(Model.Submission.FileUrl))
                        {
                            if (Model.Submission.FileUrl.EndsWith(".png") || Model.Submission.FileUrl.EndsWith(".jpg") || Model.Submission.FileUrl.EndsWith(".jpeg"))
                            {
                                <img src="@Model.Submission.FileUrl" class="img-fluid rounded border" alt="Submission file" style="max-height: 300px;" />
                            }
                            <div class="mt-2">
                                <a href="@Model.Submission.FileUrl" target="_blank" class="btn btn-outline-info">Open File Fullscreen</a>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No file attached.</p>
                        }
                    </div>
                </div>
                
                <hr class="my-4" />
                
                <h5>Make Decision</h5>
                
                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger" asp-validation-summary="All"></div>
                }

                <div class="row g-3">
                    <div class="col-md-4">
                        <form method="post" asp-page-handler="Approve" asp-route-submissionId="@Model.Submission.SubmissionId" class="card h-100 border-success">
                            <div class="card-body text-center">
                                <h6 class="text-success mb-3">Approve</h6>
                                <button type="submit" class="btn btn-success w-100">Approve Submission</button>
                            </div>
                        </form>
                    </div>
                    
                    <div class="col-md-4">
                        <form method="post" asp-page-handler="Revision" asp-route-submissionId="@Model.Submission.SubmissionId" class="card h-100 border-warning">
                            <div class="card-body">
                                <h6 class="text-warning text-center mb-3">Request Revision</h6>
                                <div class="mb-3">
                                    <textarea name="reason" class="form-control" rows="2" placeholder="What needs fixing?" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-warning w-100 text-dark">Send Back for Revision</button>
                            </div>
                        </form>
                    </div>
                    
                    <div class="col-md-4">
                        <form method="post" asp-page-handler="Reject" asp-route-submissionId="@Model.Submission.SubmissionId" class="card h-100 border-danger">
                            <div class="card-body">
                                <h6 class="text-danger text-center mb-3">Reject Completely</h6>
                                <div class="mb-3">
                                    <textarea name="reason" class="form-control" rows="2" placeholder="Why is this rejected?" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-danger w-100">Reject Task</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
