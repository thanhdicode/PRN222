@page
@model MangaWorkflow.Web.Pages.Editor.PageCommentsModel
@{
    ViewData["Title"] = "Page Comments";
}

<div class="container-fluid py-4">
    <!-- Back to Series/Chapter/Page from MVC area -->
    <div class="mb-3">
        <a asp-area="Mangaka" asp-controller="Series" asp-action="Index" class="btn btn-outline-secondary">&laquo; Back to Series</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="row">
        <!-- Left: Comments List & Form -->
        <div class="col-md-5">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Add Comment</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="AddComment">
                        <input type="hidden" asp-for="CommentInput.PageId" value="@Model.PageId" />
                        
                        <div class="mb-3">
                            <textarea asp-for="CommentInput.CommentText" class="form-control" rows="3" placeholder="Write feedback here..." required></textarea>
                            <span asp-validation-for="CommentInput.CommentText" class="text-danger"></span>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label text-muted small">Region X (optional)</label>
                                <input type="number" step="0.1" asp-for="CommentInput.RegionX" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Region Y (optional)</label>
                                <input type="number" step="0.1" asp-for="CommentInput.RegionY" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Post Comment</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Comments</h5>
                    <form method="get" class="d-flex">
                        <input type="hidden" name="pageId" value="@Model.PageId" />
                        <select asp-for="StatusFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="">All</option>
                            <option value="Open">Open</option>
                            <option value="Resolved">Resolved</option>
                        </select>
                    </form>
                </div>
                <ul class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                    @foreach (var c in Model.Comments)
                    {
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong>@c.EditorName</strong>
                                <small class="text-muted">@c.CreatedAt.ToString("g")</small>
                            </div>
                            <p class="mb-1 mt-2">@c.CommentText</p>
                            @if (c.RegionX.HasValue && c.RegionY.HasValue)
                            {
                                <small class="text-muted d-block mb-2">Location: X:@c.RegionX, Y:@c.RegionY</small>
                            }
                            
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                @if (c.StatusCode == "Open")
                                {
                                    <span class="badge bg-warning text-dark">Open</span>
                                    <form method="post" asp-page-handler="ResolveComment">
                                        <input type="hidden" name="commentId" value="@c.CommentId" />
                                        <input type="hidden" name="pageId" value="@Model.PageId" />
                                        <button type="submit" class="btn btn-sm btn-success">Resolve</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Resolved</span>
                                }
                            </div>
                        </li>
                    }
                    @if (!Model.Comments.Any())
                    {
                        <li class="list-group-item text-center text-muted py-3">No comments found.</li>
                    }
                </ul>
            </div>
        </div>
        
        <!-- Right: Page Viewer Mock -->
        <div class="col-md-7">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Page Preview</h5>
                </div>
                <div class="card-body bg-dark text-center p-5 rounded-bottom d-flex align-items-center justify-content-center" style="min-height: 500px;">
                    <div class="text-light">
                        <i class="bi bi-chat-square-dots" style="font-size: 4rem;"></i>
                        <p class="mt-3">Page Preview Area</p>
                        <small class="text-muted">In a real app, clicking the image would set X/Y for the comment.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
