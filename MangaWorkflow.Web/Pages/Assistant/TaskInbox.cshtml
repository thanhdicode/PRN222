@page
@model MangaWorkflow.Web.Pages.Assistant.TaskInboxModel
@{
    ViewData["Title"] = "Assistant Task Inbox";

    var totalTasks = Model.TaskList.Count;
    var activeTasks = Model.TaskList.Count(t => t.StatusCode == "Assigned" || t.StatusCode == "InProgress" || t.StatusCode == "RevisionRequired");
    var submittedTasks = Model.TaskList.Count(t => t.StatusCode == "Submitted");
    var overdueTasks = Model.TaskList.Count(t => t.IsOverdue || t.StatusCode == "Overdue");
}

<section class="assistant-shell">
    <div class="assistant-hero mb-4">
        <div>
            <p class="text-uppercase text-primary fw-semibold small mb-2">Assistant workspace</p>
            <h1 class="h3 mb-2">My production tasks</h1>
            <p class="text-muted mb-0">Start assigned work, submit files, and watch realtime notifications during the demo.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-page="/Assistant/TaskInbox" class="btn btn-primary">Task Inbox</a>
            <a asp-area="Assistant" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary">MVC Dashboard</a>
            <a asp-area="Assistant" asp-controller="Tasks" asp-action="Index" class="btn btn-outline-secondary">MVC Tasks</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="assistant-metric">
                <span>Total tasks</span>
                <strong>@totalTasks</strong>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="assistant-metric">
                <span>Need action</span>
                <strong>@activeTasks</strong>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="assistant-metric">
                <span>Submitted</span>
                <strong>@submittedTasks</strong>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="assistant-metric danger">
                <span>Overdue</span>
                <strong>@overdueTasks</strong>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-9">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div>
                            <h2 class="h5 mb-1">Task queue</h2>
                            <p class="text-muted small mb-0">Use this screen to demo filtering, start task, submit work, and review statuses.</p>
                        </div>
                        <form method="get" class="d-flex gap-2 align-items-center">
                            <label asp-for="StatusFilter" class="form-label small text-muted mb-0">Status</label>
                            <select asp-for="StatusFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">All Statuses</option>
                                <option value="Assigned">Assigned</option>
                                <option value="InProgress">In Progress</option>
                                <option value="Submitted">Submitted</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                                <option value="RevisionRequired">Revision Required</option>
                                <option value="Overdue">Overdue</option>
                            </select>
                            <a asp-page="/Assistant/TaskInbox" class="btn btn-sm btn-outline-secondary">Clear</a>
                        </form>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 assistant-table">
                            <thead>
                                <tr>
                                    <th>Task</th>
                                    <th>Series / Chapter</th>
                                    <th>Status</th>
                                    <th>Deadline</th>
                                    <th class="text-end">Demo action</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var task in Model.TaskList)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@task.Title</div>
                                        <div class="text-muted small">@task.TypeName</div>
                                    </td>
                                    <td>
                                        <div>@task.SeriesTitle</div>
                                        <div class="text-muted small">@task.ChapterTitle @if (task.PageNumber.HasValue) { <span> / Page @task.PageNumber</span> }</div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill @StatusClass(task.StatusCode)">@task.StatusName</span>
                                        @if (task.IsOverdue || task.StatusCode == "Overdue")
                                        {
                                            <span class="badge rounded-pill text-bg-danger ms-1">OVERDUE</span>
                                        }
                                    </td>
                                    <td>
                                        <div>@(task.Deadline?.ToString("yyyy-MM-dd") ?? "No deadline")</div>
                                        <div class="text-muted small">@DeadlineHint(task)</div>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-page="/Assistant/TaskDetail" asp-route-taskId="@task.TaskId" class="btn btn-outline-primary">Open</a>
                                            @if (task.StatusCode == "InProgress" || task.StatusCode == "RevisionRequired")
                                            {
                                                <a asp-page="/Assistant/SubmitTask" asp-route-taskId="@task.TaskId" class="btn btn-success">Submit</a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.TaskList.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        No tasks found for this filter.
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h2 class="h6">Demo checklist</h2>
                    <ol class="small text-muted ps-3 mb-0">
                        <li>Filter by status.</li>
                        <li>Open an Assigned task.</li>
                        <li>Start it to move to In Progress.</li>
                        <li>Submit work to notify Mangaka via SignalR.</li>
                    </ol>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="h6">SignalR proof</h2>
                    <p class="small text-muted mb-3">Keep this tab open as Assistant. In another tab, login as Mangaka and review a submission. The notification bell should update without refresh.</p>
                    <span class="badge text-bg-success">Realtime notifications enabled</span>
                </div>
            </div>
        </div>
    </div>
</section>

@functions {
    private static string StatusClass(string statusCode) => statusCode switch
    {
        "Assigned" => "text-bg-secondary",
        "InProgress" => "text-bg-primary",
        "Submitted" => "text-bg-warning",
        "Approved" => "text-bg-success",
        "Rejected" => "text-bg-danger",
        "RevisionRequired" => "text-bg-danger",
        "Overdue" => "text-bg-danger",
        "Cancelled" => "text-bg-dark",
        _ => "text-bg-light"
    };

    private static string DeadlineHint(TaskListItemDto task)
    {
        if (!task.Deadline.HasValue) return "Flexible";
        if (task.IsOverdue || task.StatusCode == "Overdue") return "Needs attention";
        var days = (task.Deadline.Value.Date - DateTime.UtcNow.Date).Days;
        return days < 0 ? "Needs attention" : days == 0 ? "Due today" : $"{days} day(s) left";
    }
}
