@model List<MangaWorkflow.Web.Models.AiStudio.PageSelectionViewModel>

@{
    ViewData["Title"] = "AI Studio";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0"><i class="bi bi-robot"></i> MangaWorkflow AI Studio</h3>
                    <span class="badge bg-light text-primary">AI-Assisted Workflow</span>
                </div>
                <div class="card-body">
                    <p class="lead mb-3">Select a manga page to analyze with AI detection. The system will detect regions, suggest tasks, and help you manage your production workflow.</p>

                    <!-- Workflow Steps -->
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span class="badge bg-secondary"><i class="bi bi-1-circle"></i> Select Page</span>
                        <span class="text-muted">→</span>
                        <span class="badge bg-secondary"><i class="bi bi-2-circle"></i> Analyze</span>
                        <span class="text-muted">→</span>
                        <span class="badge bg-secondary"><i class="bi bi-3-circle"></i> Accept/Reject Regions</span>
                        <span class="text-muted">→</span>
                        <span class="badge bg-secondary"><i class="bi bi-4-circle"></i> Generate Suggestions</span>
                        <span class="text-muted">→</span>
                        <span class="badge bg-secondary"><i class="bi bi-5-circle"></i> Approve Tasks</span>
                    </div>

                    <!-- Flash Messages -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No pages available. Please create a series and add chapters with pages first.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light border py-2 mb-3">
                            <strong>@Model.Count page(s)</strong> available for analysis
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:100px;">Preview</th>
                                        <th>Series</th>
                                        <th>Chapter</th>
                                        <th>Page</th>
                                        <th style="width:120px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <img src="@item.ImageUrl" alt="Preview" class="img-thumbnail"
                                                     style="max-width: 80px; max-height: 80px; object-fit: cover;"
                                                     onerror="this.src='https://via.placeholder.com/80x80?text=No+Img'" />
                                            </td>
                                            <td class="fw-semibold">@item.SeriesTitle</td>
                                            <td>Chapter @item.ChapterNumber</td>
                                            <td>Page @item.PageNumber</td>
                                            <td>
                                                <form asp-action="Analyze" method="post" class="d-inline">
                                                    <input type="hidden" name="pageId" value="@item.PageId" />
                                                    <button type="submit" class="btn btn-primary btn-sm">
                                                        <i class="bi bi-magic"></i> Analyze
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
