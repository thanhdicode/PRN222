@model MangaWorkflow.Application.DTOs.Ai.AiSegmentationResponseDto

@{
    ViewData["Title"] = "AI Segmentation Result";

    // Color coding for region types
    var regionColors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "Panel", "primary" },
        { "SpeechBubble", "info" },
        { "Character", "warning" },
        { "Background", "success" },
        { "Shading", "dark" },
        { "Effect", "danger" }
    };
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-bounding-box-circles"></i> AI Segmentation Results</h2>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-1">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Model Info Bar -->
    <div class="alert alert-light border mb-4 py-2">
        <div class="d-flex align-items-center gap-3">
            <span class="badge bg-primary"><i class="bi bi-cpu"></i> @Model.ModelName</span>
            <span class="text-muted">Version: @Model.ModelVersion</span>
            <span class="text-muted">|</span>
            <span class="badge bg-secondary">@Model.Detections.Count regions detected</span>
        </div>
    </div>

    <!-- Flash Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Left: Image + Overlay -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-image"></i> Page Image Preview</h5>
                </div>
                <div class="card-body text-center position-relative" id="image-container">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="img-fluid rounded" id="manga-page-img" alt="Manga Page"
                             onerror="this.src='https://via.placeholder.com/600x800?text=Image+Not+Found'" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/600x800?text=No+Image+Available" class="img-fluid rounded" id="manga-page-img" alt="Manga Page" />
                    }
                    <canvas id="region-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;"></canvas>
                </div>
            </div>
        </div>

        <!-- Right: Region List -->
        <div class="col-lg-5">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-crosshair"></i> Detected Regions</h5>
                    <span class="badge bg-light text-dark">@Model.Detections.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Detections.Any())
                    {
                        <div class="list-group list-group-flush" id="region-list">
                            @foreach (var region in Model.Detections)
                            {
                                var badgeColor = regionColors.TryGetValue(region.Label, out var color) ? color : "secondary";
                                var pendingAction = !region.IsAccepted.HasValue && region.DetectedRegionId != Guid.Empty;

                                <div class="list-group-item px-3 py-2"
                                     data-x="@region.X" data-y="@region.Y" data-w="@region.Width" data-h="@region.Height">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1 me-2">
                                            <!-- Region Type Badge -->
                                            <span class="badge bg-@badgeColor me-1">@region.Label</span>

                                            <!-- Confidence Bar -->
                                            <div class="progress mt-1" style="height: 6px; width: 100px; display: inline-block;">
                                                <div class="progress-bar @(region.Confidence >= 0.8m ? "bg-success" : (region.Confidence >= 0.5m ? "bg-warning" : "bg-danger"))"
                                                     role="progressbar"
                                                     style="width: @(region.Confidence * 100)%"
                                                     aria-valuenow="@(region.Confidence * 100)" aria-valuemin="0" aria-valuemax="100">
                                                </div>
                                            </div>
                                            <small class="text-muted ms-1">@region.Confidence.ToString("P0")</small>

                                            <!-- Coordinates -->
                                            <div class="mt-1">
                                                <small class="text-muted">
                                                    <i class="bi bi-pin-map"></i>
                                                    (@region.X, @region.Y) — @region.Width x @region.Height
                                                </small>
                                            </div>

                                            <!-- Status Badge -->
                                            @if (region.IsAccepted.HasValue)
                                            {
                                                <div class="mt-1">
                                                    @if (region.IsAccepted.Value)
                                                    {
                                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Accepted</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Rejected</span>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <!-- Action Buttons -->
                                        @if (pendingAction)
                                        {
                                            <div class="btn-group-vertical" role="group">
                                                <form asp-action="AcceptRegion" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="detectedRegionId" value="@region.DetectedRegionId" />
                                                    <input type="hidden" name="pageId" value="@Model.PageId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Accept Region">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                                <form asp-action="RejectRegion" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="detectedRegionId" value="@region.DetectedRegionId" />
                                                    <input type="hidden" name="pageId" value="@Model.PageId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Reject Region">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-3 text-center text-muted">
                            <i class="bi bi-emoji-neutral" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0">No regions detected.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Generate Suggestions Button -->
            <form asp-action="GenerateTaskSuggestions" method="post">
                <input type="hidden" name="pageId" value="@Model.PageId" />
                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-lightning"></i> Generate Task Suggestions
                </button>
                <small class="text-muted d-block text-center mt-1">Generate suggestions from accepted regions</small>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ai-region-overlay.js"></script>
}
